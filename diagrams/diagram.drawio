<mxfile host="app.diagrams.net" modified="2025-11-28T12:00:00.000Z" agent="ChatGPT" version="20.2.8">
  <diagram id="aws-multi-region" name="AWS Multi-Region Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <!-- Required roots -->
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Internet / Global -->
        <mxCell id="internet" value="Internet / Users" style="ellipse;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="100" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="route53" value="Route 53" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#E3F2FD;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="30" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="cloudfront" value="CloudFront" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#E8F5E9;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="30" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Edge: Internet -> Route53 -> CloudFront -->
        <mxCell id="e1" edge="1" parent="1" source="internet" target="route53" style="endArrow=block;strokeColor=#000000;"/>
        <mxCell id="e2" edge="1" parent="1" source="route53" target="cloudfront" style="endArrow=block;strokeColor=#000000;"/>

        <!-- Region A Group -->
        <mxCell id="regionA" value="Region A (us-east-1)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1B75BC;fillColor=#F3F8FF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="430" height="320" as="geometry"/>
        </mxCell>

        <!-- ALB A -->
        <mxCell id="albA" value="ALB - Region A" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=11;" vertex="1" parent="regionA">
          <mxGeometry x="30" y="40" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- App Tier A -->
        <mxCell id="appA" value="App Tier (EC2/Containers)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=11;" vertex="1" parent="regionA">
          <mxGeometry x="220" y="40" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- DB A -->
        <mxCell id="dbA" value="RDS (Multi-AZ, Encrypted)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFF3E0;fontSize=11;" vertex="1" parent="regionA">
          <mxGeometry x="120" y="140" width="190" height="50" as="geometry"/>
        </mxCell>

        <!-- S3 A -->
        <mxCell id="s3A" value="S3 (Static Assets / Backups)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#E1F5FE;fontSize=11;" vertex="1" parent="regionA">
          <mxGeometry x="30" y="230" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges in Region A -->
        <mxCell id="e3" edge="1" parent="regionA" source="albA" target="appA" style="endArrow=block;strokeColor=#000000;"/>
        <mxCell id="e4" edge="1" parent="regionA" source="appA" target="dbA" style="endArrow=block;strokeColor=#000000;"/>

        <!-- Edge CloudFront -> ALB A -->
        <mxCell id="e5" edge="1" parent="1" source="cloudfront" target="albA" style="endArrow=block;strokeColor=#000000;"/>

        <!-- Region B Group -->
        <mxCell id="regionB" value="Region B (us-west-2)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#1B75BC;fillColor=#F3F8FF;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="130" width="430" height="320" as="geometry"/>
        </mxCell>

        <!-- ALB B -->
        <mxCell id="albB" value="ALB - Region B" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=11;" vertex="1" parent="regionB">
          <mxGeometry x="30" y="40" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- App Tier B -->
        <mxCell id="appB" value="App Tier (EC2/Containers)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFFFFF;fontSize=11;" vertex="1" parent="regionB">
          <mxGeometry x="220" y="40" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- DB B -->
        <mxCell id="dbB" value="RDS (Read Replica / DR)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFF3E0;fontSize=11;" vertex="1" parent="regionB">
          <mxGeometry x="120" y="140" width="190" height="50" as="geometry"/>
        </mxCell>

        <!-- S3 B -->
        <mxCell id="s3B" value="S3 (Cross-Region Replication)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#E1F5FE;fontSize=11;" vertex="1" parent="regionB">
          <mxGeometry x="30" y="230" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges in Region B -->
        <mxCell id="e6" edge="1" parent="regionB" source="albB" target="appB" style="endArrow=block;strokeColor=#000000;"/>
        <mxCell id="e7" edge="1" parent="regionB" source="appB" target="dbB" style="endArrow=block;strokeColor=#000000;"/>

        <!-- Edge CloudFront -> ALB B -->
        <mxCell id="e8" edge="1" parent="1" source="cloudfront" target="albB" style="endArrow=block;strokeColor=#000000;"/>

        <!-- Cross-region replication arrows -->
        <mxCell id="e9" edge="1" parent="1" source="dbA" target="dbB" style="endArrow=block;dashed=1;strokeColor=#FF9800;" value="DB Replication"/>
        <mxCell id="e10" edge="1" parent="1" source="s3A" target="s3B" style="endArrow=block;dashed=1;strokeColor=#FF9800;" value="S3 CRR"/>

        <!-- Logging / SIEM -->
        <mxCell id="siem" value="Central Logging / SIEM (Rapid7)" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#000000;fillColor=#FFF9C4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="980" y="60" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- Edges from Regions to SIEM -->
        <mxCell id="e11" edge="1" parent="1" source="regionA" target="siem" style="endArrow=block;dashed=1;strokeColor=#616161;" value="Logs / Metrics"/>
        <mxCell id="e12" edge="1" parent="1" source="regionB" target="siem" style="endArrow=block;dashed=1;strokeColor=#616161;" value="Logs / Metrics"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
